<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ColorSelectionController" spacing="20" alignment="CENTER"
      prefWidth="450" prefHeight="350"
      style="-fx-background-color: #f5e6d3;">
    <padding>
        <Insets top="30" bottom="30" left="30" right="30"/>
    </padding>

    <Label text="🎮 Escolha a cor das peças" alignment="CENTER"
           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #5d4e37;"/>

    <VBox spacing="12" style="-fx-border-color: #8b7355; -fx-border-radius: 8; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #faf6f1;">
        <Button fx:id="blackButton" text="⬛ Peças Pretas" prefWidth="310" prefHeight="50"
                style="-fx-font-size: 12; -fx-font-weight: bold; -fx-base: #5d4e37; -fx-text-fill: white; -fx-padding: 10; -fx-cursor: hand;"/>

        <Button fx:id="whiteButton" text="⬜ Peças Brancas" prefWidth="310" prefHeight="50"
                style="-fx-font-size: 12; -fx-font-weight: bold; -fx-base: #c9a98b; -fx-text-fill: #5d4e37; -fx-padding: 10; -fx-cursor: hand;"/>

        <Button fx:id="randomButton" text="🎲 Aleatório" prefWidth="310" prefHeight="50"
                style="-fx-font-size: 12; -fx-font-weight: bold; -fx-base: #a9927d; -fx-text-fill: white; -fx-padding: 10; -fx-cursor: hand;"/>
    </VBox>
</VBox>

