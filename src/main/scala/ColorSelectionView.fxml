<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ColorSelectionController" spacing="20" alignment="CENTER"
      prefWidth="400" prefHeight="300">
    <padding>
        <Insets top="30" bottom="30" left="30" right="30"/>
    </padding>

    <Label text="Escolha a cor das peças" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <VBox spacing="10" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
        <Button fx:id="blackButton" text="Pretas" prefWidth="300" prefHeight="50"/>
        <Button fx:id="whiteButton" text="Brancas" prefWidth="300" prefHeight="50"/>
        <Button fx:id="randomButton" text="Aleatório" prefWidth="300" prefHeight="50"/>
    </VBox>
</VBox>

